# Auth configuration. Copy to `.env` for local dev (`vercel dev`) and set the
# same values in the Vercel project (Production + Preview + Development).
# `.env*` is gitignored — never commit real values.

# Google OAuth Client ID (Web application). Public — inlined into the client
# bundle for the "Sign in with Google" button. The VITE_ prefix is required for
# Vite to expose it to the browser.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Same Client ID, read server-side to verify the `aud` claim of the ID token.
# Kept as a separate (non-VITE_) var so server code never depends on a
# client-exposed name.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google OAuth client SECRET — server-only. Used ONLY by the /api/oauth
# redirect fallback (authorization-code exchange) for browsers where the
# in-page Google button (GIS) can't run, e.g. older Android WebViews. The GIS
# ID-token path (/api/auth) does not need it. Copy it from the same OAuth client
# in Google Cloud. You must ALSO add an Authorized redirect URI to that client:
#   https://<your-production-domain>/api/oauth
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# Secret used to HMAC-sign the session cookie. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=replace-with-a-long-random-string

# Allowlist mapping Google emails to crew members. Comma-separated
# "email:Person" pairs; emails are compared case-insensitively. Only these
# accounts can sign in.
ALLOWED_EMAILS=grant@example.com:Grant,desmond@example.com:Desmond,lawrence@example.com:Lawrence

# Comma-separated emails allowed to publish lineup overrides via POST /api/lineup.
# Leave blank to allow any authenticated session (current behaviour; tighten in PR-3).
ADMIN_EMAILS=grant@example.com
